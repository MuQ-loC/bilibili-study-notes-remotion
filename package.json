{
  "name": "bilibili-study-notes-remotion",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "web:dev": "vite frontend --host 127.0.0.1 --port 8794",
    "web:build": "tsc -p frontend/tsconfig.json && vite build frontend",
    "ai:api": "tsx scripts/deepseek-video-api.ts",
    "video:script": "tsx scripts/extract-voiceover-script.ts",
    "voice:import": "tsx scripts/import-reference-voice.ts",
    "video:tts": "tsx scripts/generate-voiceover.ts",
    "video:captions:raw": "tsx scripts/transcribe-voiceover.ts",
    "video:captions:fix": "tsx scripts/correct-voiceover-captions.ts",
    "video:captions": "npm run video:captions:raw && npm run video:captions:fix",
    "video:preview": "remotion studio remotion/index.ts --public-dir=public",
    "video:render": "remotion render remotion/index.ts XiaohongshuTutorial out/xiaohongshu-tutorial.mp4 --codec=h264 --public-dir=public",
    "video:render:ai": "remotion render remotion/index.ts DeepSeekGenerated out/deepseek-generated.mp4 --codec=h264 --public-dir=public"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@remotion/cli": "4.0.474",
    "@vitejs/plugin-react": "^5.1.1",
    "antd": "^6.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "4.0.474",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
